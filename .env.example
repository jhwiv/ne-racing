# Railbird AI — data source configuration
# Copy to .env (git-ignored) and fill in real values. Never commit secrets.

# Which adapter the ingester + worker should use.
# Valid: sample, theracingapi
DATA_SOURCE=sample

# Only required when DATA_SOURCE=theracingapi.
# Sign up at https://www.theracingapi.com (North America add-on needed for NYRA/Saratoga).
# THERACINGAPI_USER=
# THERACINGAPI_PASS=

# Training allow-list. Records whose license_tier is NOT in this list are
# excluded from training output. Keep tight.
# Valid values: green, yellow
ALLOW_LICENSE_TIER=green,yellow

# Admin dashboard bearer token (when we ship admin.html in Phase 4).
# ADMIN_BEARER_TOKEN=
